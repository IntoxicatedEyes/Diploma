#Сделаем таблицу, где в строках "Кликнул / не кликнул", в столбцах "Купил / не купил", а на пересечении - результат.

def contingency_2x2(recs: list[dict], a_key: str, b_key: str) -> list[list[int]]:
    """2x2 таблица частот для бинарных признаков a_key и b_key (значения 0/1)."""
    # TODO: создайте table=[[0,0],[0,0]] и заполните её циклом по recs
    table = [[0,0], [0,0]]
    #Здесь мы снова идем по индексам в списке из ячейки 1 и речь идет о парах признаков. Все признаки переводим в 0 и 1 и построим бинарную матрицу
    for r in recs:
        a = int(r[a_key])
        b = int(r[b_key])
        if a not in (0, 1) or b not in (0, 1):
          raise ValueError("Значения должны быть 0 или 1")
        table[a][b] += 1
    return table


