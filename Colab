def variance_sample(values) -> float:
    # TODO: реализуйте выборочную дисперсию: sum((x-m)^2)/(n-1)
    n = len(values)
    if n < 2:
        raise ValueError("для расчета выборочной дисперсии и стандартного отклонения нужно минимум 2 наблюдения")
    m = mean(values) #m - это среднее всех значений
    return float(sum((x - m) ** 2 for x in values)) / (n - 1)  #берем разницу измерения каждого из 80 элементов и находим разницу отклонения от среднего.
                                                               # Если х больше среднего, у нас положительное отклонение, а если х меньше среднего, у нас отрицательное отклонение.
                                                               # Когда возводим в квадрат, получаем положительное значение, избавляясь от минуса.
                                                               # Чем больше отклонение x от m, еще и возведенное в квадрат, мы "наказываем" большие отклонения, но затем берем квадратный корень в стандарном отклонении.
                                                               # Дисперсия и станд. отклонение всегда работают в связке, показывая насколько от центра разбросаны измерения (Мой центр - это 15, а разброс - 4).


def std_sample(values) -> float:
