def bootstrap_means(values, n_boot: int = 5000, seed: int = 0):
    # TODO: реализуйте список из n_boot средних, полученных бутстрэпом

    rng = np.random.default_rng(seed) # рандом для генерации много раз
    values = np.asarray(values)
    n = len(values)
    if n == 0:
        raise ValueError("значения для бустстрэпа не должны быть пусты")
    means = [] # Сюда сложатся все значения бустстрэпа
    for _ in range(n_boot):
        idx = rng.integers(0, n, size=n)  # выборка индексов с возвращением
        sample_b = values[idx] #расширяем выборку и делаем еще 148 подобных
        means.append(float(np.mean(sample_b)))
    return means


